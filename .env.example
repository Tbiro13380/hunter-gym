# ==========================================
# Hunter Gym — Variáveis de Ambiente
# ==========================================
# Copie para .env e preencha. Prefixos SUPABASE_/VAPID_ são expostos ao cliente
# pelo Vite (trate como públicos no bundle).

# OpenAI: NÃO coloque no .env do front — use secrets do Supabase na função shadow-coach.

# Supabase — Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Web Push — par VAPID (ex.: npx web-push generate-vapid-keys); só a chave pública aqui
VAPID_PUBLIC_KEY=

# ==========================================
# Hunter Gym — Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores

# OpenAI API Key (obrigatório para o Shadow Coach)
# Obtenha em: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Supabase (URL + anon key do projeto — Dashboard > Settings > API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Web Push (opcional — gerar par VAPID, ex.: npx web-push generate-vapid-keys)
# Chave pública no app; chave privada só no servidor / Edge Function
VITE_VAPID_PUBLIC_KEY=
